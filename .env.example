# Database & Cache Settings
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/meeting_prep
REDIS_URL=redis://localhost:6379/0

# Security & JWT Configuration
JWT_SECRET_KEY=generate-a-long-random-string-here-minimum-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# Base64 encoded 32-byte Fernet key. Generate with: cryptography.fernet.Fernet.generate_key().decode()
TOKEN_ENCRYPTION_KEY=your-fernet-token-encryption-key-here=

# Google OAuth Integration
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Third Party APIs
OPENAI_API_KEY=your-openai-api-key
SERPAPI_API_KEY=your-serpapi-api-key

# Pinecone Vector Database Config
PINECONE_API_KEY=your-pinecone-api-key
# Host or environment parameter depending on your Pinecone project type
PINECONE_INDEX_NAME=meeting-prep-index
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_HOST=https://meeting-prep-index-xxxxxxx.svc.us-east-1-aws.pinecone.io
